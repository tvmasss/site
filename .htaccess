RewriteEngine On
RewriteBase /

# 1. Внешний редирект: с jobs.html на /jobs/ (для SEO и единообразия)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+([^.]+)\.html [NC]
RewriteRule ^ /%1/ [R=301,L]

# 2. Внутренняя подмена: при обращении к /jobs/ сервер читает jobs.html
# Проверяем, что это не папка, а файл с .html существует
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]
